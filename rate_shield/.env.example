
# RateShield Configuration
# Copy this file to .env and fill in the values

# Application Configuration
RATE_SHIELD_PORT=8080
ENV=dev

# JWT — use a long random string, never share this
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# Google OAuth — get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# URLs
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:8080

# SMTP — for email verification (Gmail: use App Password from Google Account > Security)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Redis Rules Instance (Single Redis instance for storing rate limit rules)
REDIS_RULES_INSTANCE_URL=localhost:6379
REDIS_RULES_INSTANCE_USERNAME=
REDIS_RULES_INSTANCE_PASSWORD=

# Redis Cluster Configuration (For distributed rate limiting)
REDIS_CLUSTERS_URLS=localhost:6379
REDIS_CLUSTER_USERNAME=
REDIS_CLUSTER_PASSWORD=

# Slack Notifications (Required — set dummy values if not using)
SLACK_TOKEN=your-slack-token
SLACK_CHANNEL=your-slack-channel-id
